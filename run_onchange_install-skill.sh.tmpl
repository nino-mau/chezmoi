#!/bin/bash
# Triggered when: {{ include ".chezmoidata/skills.yaml" | sha256sum }}
set -euo pipefail
{{- if .skills.bunx }}
packages=(
{{- range .skills.bunx }}
  {{ . | quote }}
{{- end }}
)
if command -v bunx >/dev/null 2>&1; then
  installed_json="$(bunx skills list -g --json)"
  did_install=false

  for package in "${packages[@]}"; do
    skill_name="${package##*@}"
    if grep -Fq "\"name\": \"$skill_name\"" <<<"$installed_json"; then
      continue
    fi

    bunx skills add "$package" -g -y
    installed_json+=$'\n'"\"name\": \"$skill_name\""
    did_install=true
  done

  if [[ "$did_install" == true ]]; then
    bunx skills update
  fi
else
  echo "bunx is not installed" >&2
  exit 1
fi
{{- end }}
