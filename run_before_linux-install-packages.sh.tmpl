{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash
# Triggered when: {{ include ".chezmoidata/packages.yaml" | sha256sum }}
set -euo pipefail
{{- if .packages.linux.paru }}
packages=(
{{- range .packages.linux.paru }}
  {{ . | quote }}
{{- end }}
)
if ! command -v paru >/dev/null 2>&1; then
  echo "warning: paru is not installed, skipping package installation" >&2
  exit 0
fi

if ! paru -S --needed --noconfirm "${packages[@]}"; then
  echo "warning: package installation failed, continuing chezmoi apply" >&2
fi
{{- end }}
{{- end }}
