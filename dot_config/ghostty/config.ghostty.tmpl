# ====================
# KEYBINDS
# ====================

keybind = ctrl+f=start_search
keybind = super+ctrl+-=decrease_font_size:0.5
keybind = super+ctrl++=increase_font_size:1
keybind = performable:ctrl+n=goto_split:next
keybind = performable:ctrl+c=copy_to_clipboard
keybind = ctrl+shift+e=text:\u{00E8}
keybind = ctrl+shift+a=text:\u{00E0}
macos-option-as-alt = false

# ====================
# THEMES
# ====================

# Load theme
config-file = ./theme

# ====================
# WINDOW
# ====================

# window-width = 140
# window-height = 40

window-decoration = none
macos-window-shadow = false
macos-titlebar-style = hidden

window-padding-x = 20
window-padding-y = 20
window-padding-balance = true

# Controls closing confirmation
confirm-close-surface = false

background-opacity = 0.8
{{ if eq .chezmoi.os "darwin" }}
background-blur-radius = 50
{{ else }}
# background-blur-radius = 50
{{ end }}

# ====================
# NOTIFICATION
# ====================

notify-on-command-finish = always
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 30s

# ====================
# FONT
# ====================

# font-family = JetBrainsMono Nerd Font
# font-family = JetBrains Maple Mono Nerd Font
font-family = Maple Mono NF
# font-family = Smiley Sans
# font-family = SourceCodePro
# font-family = GeistMonoNerdFont
# font-family = IosevkaNerdFontPropo
# font-family = FiraCode Nerd Font Mono
# font-family = SpaceMono Nerd Font

{{ if eq .chezmoi.os "darwin" }}
font-size = 15
# adjust-cell-height = 10%
{{ else }}
font-size = 12
{{ end }}

# Line height equivalent
# adjust-cell-height = 1

# ====================
# CURSOR
# ====================

# Color of the cursor is defined in theme file

# Change cursor style
# cursor-style = block

# ====================
# SHELL
# ====================

shell-integration = fish
shell-integration-features = no-cursor 

# ====================
# SHADERS
# ====================

# Fix for shaders to correctly compute the cursor color
alpha-blending = linear-corrected

{{ if eq .chezmoi.os "darwin" }}
custom-shader = shaders/cursor_sweep.glsl
{{ else }}
custom-shader = shaders/cursor_sweep.glsl
# custom-shader = shaders/cursor_smear_custom.glsl
# custom-shader = shaders/cursor_blaze_notrail_custom.glsl
{{ end }}

# ====================
# GRAPHICS
# ====================

# Enable Kitty graphics protocol
image-storage-limit = 320000000
