{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(npm run *)",
      "Bash(bun run *)",
      "Bash(git ls *)",
      "Bash(ls*)",
      "Read(~/Code/**)",
      "Edit(~/Code/projects/**)",
      "Read(~/Code/projects/**)"
    ],
    "deny": [
      "Read(*.env)",
      "Bash(curl:*)",
      "Bash(rm *)"
    ],
    "ask": [
      "Bash(gh pr create:*)",
      "Bash(git commit:*)"
    ],
    "defaultMode": "default"
  },
  "model": "claude-fable-5[1m]",
  "theme": "dark-ansi",
  "editorMode": "vim"
}
