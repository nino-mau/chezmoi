{
  "$schema": "https://opencode.ai/config.json",
  "provider": {},
  "permission": {
    "external_directory": "allow",
    "edit": "ask",
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "rm -rf *": "deny",
      "sed *": "ask",
      "touch *": "ask"
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "color": "primary",
      "model": "openai/gpt-5.4"
    },
    "full": {
      "mode": "primary",
      "color": "error",
      "model": "openai/gpt-5.4",
      "permission": {
        "external_directory": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "allow"
      }
    },
    "chat": {
      "mode": "primary",
      "color": "secondary",
      "model": "openai/gpt-5.4",
      "permission": {
        "external_directory": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "deny"
      }
    }
  },
  "default_agent": "build"
}
